{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Manifold",
  "version": "0.4.0",
  "identifier": "me.bitnet.manifold",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Manifold",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Bulk-manage Steam launch options and Proton compatibility",
    "longDescription": "Manifold bulk-manages Steam games' launch options and forced Proton/compatibility tool. Compose launch lines from a catalogue of building blocks, save them as presets, and apply across many games with guarded, backed-up writes.",
    "homepage": "https://github.com/yasen-pavlov/manifold",
    "publisher": "Yasen Pavlov",
    "copyright": "Copyright (c) 2026 Yasen Pavlov",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
